 kamu sekarang. Tidak perlu khawatir, tidak ada soal yang rumit kok! Selain itu tidak ada jawaban yang benar salah kok!"},{question:"Apakah saya perlu menunggu untuk melihat hasil dari Tes Minat Bakat?",answer:"Hasil Tes Minat Bakat bisa langsung kamu peroleh setelah selesai menjawab semua pertanyan."},{question:"Apa saja manfaat yang saya peroleh dengan mengikuti Tes Minat Bakat ini?",answer:"Hasil Tes Minat Bakat Quipper Campus bisa jadi rujukan kamu dalam memilih jurusan ketika kuliah dan juga dalam meniti karier di masa depan. "},{question:"Mengapa hasil Tes Minat Bakat saya berubah-ubah?",answer:"Hasil tes bisa berubah jika terjadi perubahan dari diri kamu. Hal ini bisa disebabkan oleh berbagai faktor (seperti minat, kepribadian dan motivasi) . Untuk hasil yang lebih akurat, kamu perlu mengerjakan tes ini sesuai dengan diri kamu dengan apa adanya bukan apa yang menurut kamu paling baik."}]},function(e,t,n){"use strict";Object.defineProperty(t,"__esModule",{value:!0}),t.default=void 0;var o=l(n(11)),r=l(n(256)),a=l(n(185)),s=l(n(120)),c=l(n(121)),i=n(36);function l(e){return e&&e.__esModule?e:{default:e}}var p=(0,r.default)({chartName:"RadarChart",GraphicalChild:a.default,axisComponents:[{axisType:"angleAxis",AxisComp:s.default},{axisType:"radiusAxis",AxisComp:c.default}],formatAxisMap:i.formatAxisMap,defaultProps:{layout:"centric",startAngle:90,endAngle:-270,cx:"50%",cy:"50%",innerRadius:0,outerRadius:"80%"},propTypes:{layout:o.default.oneOf(["centric"]),startAngle:o.default.number,endAngle:o.default.number,cx:o.default.oneOfType([o.default.number,o.default.string]),cy:o.default.oneOfType([o.default.number,o.default.string]),innerRadius:o.default.oneOfType([o.default.number,o.default.string]),outerRadius:o.default.oneOfType([o.default.number,o.default.string])}});t.default=p},function(e,t,n){var o=n(49),r=n(673),a=n(161),s=n(674),c=a(function(e){var t=o(e,s);return t.length&&t[0]===e[0]?r(t):[]});e.exports=c},function(e,t,n){"use strict";Object.defineProperty(t