escription:"Yuk, ikutan tes Minat Bakat Quipper Campus untuk mengetahui Jurusan yang paling cocok untuk kamu!",this_major_is_for_you_button:"Ikuti tes!",school_with_major:"Kampus yang memiliki jurusan {major}",see_other_school:"Lihat Kampus Lainnya"}},numbers:{salary:"{salary, number, IDR}"}}},function(e){e.exports={home:"Beranda",headline:"Info Kampus Terlengkap dan Berkualitas",login:"Masuk",sign_up:"Daftar",logout:"Keluar",guest:"Pengunjung",edit_profile:"Ubah Profil",favorite:"Favorit",or:"Atau",next:"Lanjut",done:"Selesai",save:"Simpan",cancel:"Batal",banner_title:"Informasi Menarik Persiapan Kuliahmu!",search_box_title:"Cari Lokasi Kampus dan Program Studi Favorit di Sini",navs:{majors:"Jurusan"},why_quipper:{header:"Kenapa Memilih Quipper Campus?",not_registered_yet:"Belum Daftar Quipper Campus?",get_more_info_with_register_to_quipper_campus:"Dapatkan informasi lebih lengkap dengan mendaftar Quipper Campus",register_free:"Daftar Gratis!",title:{1:"Mudah Diakses",2:"Informasi Berkualitas",3:"Gratis Selamanya"},desc:{1:"Terintegrasi secara offline dan online, Quipper Campus memenuhi kebutuhanmu dalam mencari informasi terpercaya.",2:"Quipper Campus menyediakan informasi pendidikan tinggi berkualitas nomor satu dalam satu portal!",3:"Layanan ini bebas biaya, silakan gunakan sepuasmu."}},aptitude:{banner:{title:"Masih bimbang dengan masa depanmu?",desc:"Yuk, ikutan Test Minat Bakat"},interest:"Minat",personality:"Kepribadian",landing:{title_1:"Masih Bimbang dengan Masa Depanmu?",desc_1:"Yuk ikut Tes Minat Bakat dan langsung dapatkan hasilnya!",title_2:"Apa itu test minat bakat?",desc_2:"Jurusan apa yang harus kamu pilih? Melalui tes minat bakat ini, kamu dapat mengetahui jawaban dari semua pertanyaan tersebut. Ikuti tesnya dengan menjawab beberapa soal sederhana tentang diri kamu.",title_3:"Lihat Hasil Tes Kamu",desc_3:"Di akhir tes, kamu akan mendapatkan rekomendasi jurusan dan karier yang cocok dengan karaktermu.",test_now:"Ikuti Tes Minat Bakat!",previous_test:"Hasil test sebelumnya"},instructions:{1:"Terdapat 2 bagian: <ol type='a'><li>Tes Mengenali Minat (99 soal)</li><li>Tes Mengenali Kepribadian (39 soal)</li></ol>",2:"Tidak ada jawaban benar/salah, silakan pilih jawaban yang paling sesuai dengan diri kamu",3:"Tidak ada batas waktu pengerjaan. Namun biasanya, tes ini memakan waktu sekitar 20 menit",4:"Seluruh soal harus dijawab (tidak boleh ada yang terlewat)",5:"Kamu tidak bisa mundur, setelah memulai tes",6:"Setelah klik “Next/Lanjut” atau “Submit/Kumpulkan”, kamu tidak bisa mengganti jawabanmu",7:"Sistem akan menyimpan setiap jawabanmu setelah kamu klik tombol “Next/Lanjut” dan “Submit/Kumpulkan”",8:"Jika kamu keluar secara sengaja ataupun tidak di tengah tes, kamu dapat login dan melanjutkan kembali dari halaman terakhir saat kamu keluar tes",9:"Kamu membutuhkan akun Quipper untuk bisa mengakses tes ini. ",10:"Lakukan Sign up/login terlebih dulu",11:"Saat kamu siap melakukan tes, klik tombol “Mulai”",title:"Pengenalan Test",subtitle:"Test Minat Bakat",last:"Selamat mengerjakan Tes Minat Bakat!",good_luck:"Selamat mengerjakan!"},questions:{bar:{title:"Petunjuk Test",example:"Contoh",information:"Keterangan",riasec:{page_name:"Minat",subtitle_1:"Silakan pilih salah satu dari skala yang mewakili diri Anda dari setiap pernyataan",subtitle_2:'"Apakah Anda tertarik atau ingin melakukan pekerjaan atau kegiatan di bawah ini?"',answer:{1:"Tidak setuju",2:"Agak tidak setuju",3:"Di tengah-tengah",4:"Agak setuju",5:"Setuju"},example:"Saya suka belajar di malam hari"},charcs:{page_name:"Kepribadian",subtitle_1:"Silakan beri tanda pada setiap pernyataan:",subtitle_2:'"Dari pernyataan-pernyataan di bawah ini, manakah yang paling mendekati Anda sehari-hari?"',answer:{1:"Mendekati pernyataan di sebelah kiri",2:"Hampir mendekati pernyataan di sebelah kiri",3:"Hampir mendekati pernyataan di sebelah kanan",4:"Mendekati pernyataan di sebelah kanan"},example_1:"Saya Suka Matematika",example_2:"Saya Suka Bahasa Indonesia"}}},result:{page_name:"Hasil test",your_test_results:"Hasil tes kamu",who_you_are:"Siapakah kamu",your_character_type:"Tipe karakter kamu",download_full_report:"Unduh Laporan Lengkap",interest:{tab_text:"Minat",title:"Siapakah kamu"},study_field:{tab_text:"Jurusan",title:"3 Jurusan Paling Cocok",subtitle:"Di bawah ini adalah 3 Jurusan yang paling cocok sesuai minat dan bakat kamu. Dan kamu juga bisa mengunduh brosur-brosur dari kampus-kampus yang menyediakan jurusan-jurusan sesuai minat kamu.",download:"Unduh Brosur Kampus",download_desc:"Unduh brosur dengan mencentang simbol",see_more:"Lihat kampus lain",download_selected:"Unduh brosur kampus yang dipilih",select_all:"Pilih semua"},career:{tab_text:"Karier",title:"Karier Untuk Kamu",subtitle:"Di bawah ini merupakan urutan karier yang paling cocok untuk kamu, berdasarkan hasil tes minat dan bakat yang telah kamu selesaikan sebelumnya.",download_desc:"Untuk melihat karier lengkap kamu, silakan tekan tombol di bawah ini"},download_report:{tab_text:"Unduh",title:"Dapatkan Laporan Lengkap",subtitle:"Unduh dan lihat hasil tes lengkap tentang minat dan bakat kamu. Kamu juga bisa melihat prospek karier dan jurusan yang cocok untuk menjadi peluang kamu di masa depan.",send_to_email:{true:"Email sudah dikirim!",false:"Kirim laporan via email"},send_email_failed:"Gagal mengirim email!",download_brocures:"Kamu harus download {count} brosur terlebih dahulu."},history:{nav_link:"Riwayat Tes Minat Bakat",page_name:"Riwayat",no_entry:"Riwawat Kosong",title:"Riwayat hasil test kamu",see_detail:"Lihat detail",take_new_test:"Ikuti tes baru"}}},validations:{is_taken:"{field} sudah digunakan!",required:"{field} harus diisi!",email:"Gunakan alamat email yang valid",username:"Nama Pengguna hanya bisa terdiri dari huruf, angka, dan karakter ini: - _ .",email_username:"Gunakan format nama pengguna atau alamat email yang valid",phone_number:"Nomor telepon hanya bisa terdiri dari 8 hingga 13 angka",contains_text_and_number:"Kata Sandi harus kombinasi anta