imgAlt:"Zahra | Testimoni Tes Minat Bakat - Quipper Campus",testimony:'"Hari ini aku mengerjakan Tes Minat Bakat dari Quipper Campus, hasilnya sesuai banget dengan yang aku mau, jurusan dan karier yang aku pengen semua ada di rekomendasinya."'},{name:"Ratu Azzahra",jobTitle:"Guru",schoolName:"SMAS IT Insan Mandiri",img:"/assets/img/aptitude/ratu-azzahra.jpg",imgAlt:"Ratu Azzahra | Testimoni Tes Minat Bakat - Quipper Campus",testimony:"\"Tes Minat Bakat yang diselenggarakan Quipper Campus bisa menjadi salah satu rekomendasi sebagai 'kompas' pemilihan program studi berdasarkan minat dan bakat siswa.\""}]},function(e){e.exports=[{id:"riasec-r",title:"Realistic",content:"Sering menggunakan benda seperti alat-alat, mesin, serta suka memelihara hewan dan tumbuhan. Terpaku dan memiliki fokus yang baik dalam mengerjakan sesuatu yang disukai.",fullContent:["Tipe kepribadian ini sangat terampil menggunakan peralatan seperti alat-alat, mesin, serta suka memelihara hewan dan tumbuhan.","Pada umumnya tidak terlalu senang mengikuti kegiatan yang berhubungan dengan orang banyak seperti mengajar dan menyampaikan informasi ke orang lain.","Melihat diri sendiri sebagai seorang yang praktikal dan mengesampingkan hal-hal yang dianggap tidak berguna.","Terpaku dan memiliki fokus yang baik dalam mengerjakan sesuatu yang disukai.","Karier yang sesuai: Programmer, Dokter Gigi, dan Arsitek."]},{id:"riasec-i",title:"Investigative",content:"Suka mencari tahu struktur dan teori terhadap suatu hal yang terstruktur alamiah dan aturan-aturan dalam masyarakat. Memiliki rasa ingin tahu yang tinggi, serta menyukai ide-ide baru.",fullContent:["Tipe kepribadian ini menyukai hal-hal yang berdasarkan teori ilmiah.","Sangat terampil dalam memecahkan masalah atau perhitungan matematika yang kompleks.","Memiliki rasa ingin tahu yang tinggi, serta menyukai ide-ide baru.","Menghindari kegiatan yang membutuhkan banyak berinteraksi dengan orang lain seperti membujuk dan memasarkan sesuatu.","Melihat diri sendiri sebagai seorang yang intelektual","Karier yang sesuai: Pengacara, Web Developer, dan Psikolog."]},{id:"riasec-a",title:"Artistic",content:"Suka mengekspresikan diri dalam bentuk gambar, lukisan, musik, sastra, dan drama. Lebih peka terhadap rasa dan perasaan, serta lebih mementingkan kebebasan daripada apapun. ",fullContent:["Tipe kepribadian ini menyukai kegiatan yang memerlukan kreativitas, seperti seni, drama, kerajinan, musik dan menulis kreatif.","Senang mengekspresikan diri melalui karya seni yang dibuat.","Lebih peka terhadap rasa dan perasaan, serta lebih mementingkan kebebasan daripada apapun.","Melihat diri sendiri sebagai seseorang yang orisinal dan independen.","Karier yang sesuai: Fashion Designer, Musisi, dan Fotografer."]},{id:"riasec-s",title:"Social",content:"Suka membantu orang, mendidik, dan bisa menjalin hubungan yang baik dengan lingkungan sekitar. Bisa mengendalikan diri, sabar, serta baik pada orang lain. ",fullContent:["Tipe kepribadian ini menyukai kegiatan yang memberikan manfaat kepada orang lain.","Suka membantu orang, mendidik, dan bisa menjalin hubungan yang baik dengan lingkungan sekitar.","Bisa mengendalikan diri, sabar, serta baik pada orang lain.","Melihat diri sendiri sebagai seseorang yang baik, ramah dan mudah bergaul.","Karier yang sesuai: Guru, Dokter,  dan Human Resources (HRD)."]},{id:"riasec-e",title:"Enterprising",content:"Berusaha mencapai dan mewujudkan tujuan bersama, suka bernegosiasi dan berdiskusi. Mempunyai kepercayaan diri dalam bergaul dan bermasyarakat, bisa memimpin, serta bisa memberikan pengaruh kepada orang lain. ",fullContent:["Tipe kepribadian ini senang menjadi pemimpin dan mempengaruhi orang lain.","Sangat baik dalam menyampaikan ide dan bernegosiasi.","Pada umumnya menghindari hal-hal teknis yang kompleks dan memerlukan observasi mendalam.","Melihat diri sendiri sebagai seseorang yang penuh semangat, ambisius dan mudah bergaul.","Karier yang sesuai: Wirausaha/Entrepreneur, Sales, dan Produser."]},{id:"riasec-c",title:"Conventional",content:"Suka mengurusi berkas-berkas, menganalisa data, serta bekerja sesuai langkah atau urutan yang telah ditentukan. Tertib dan mematuhi aturan, serta berhati-hati dalam melakukan sesuatu. ",fullContent:["Tipe kepribadian ini senang berurusan dengan hal-hal administratif.","Suka mengurusi berkas-berkas, menganalisa data, serta bekerja sesuai langkah atau urutan yang telah ditentukan.","Tertib dan mematuhi aturan, serta berhati-hati dalam melakukan sesuatu. ","Melihat diri sendiri sebagai seseorang rapi, disiplin dan terencana.","Karier yang sesuai: Finance/Akuntan, Administrasi, dan Reporter."]}]},function(e,t){var n=Object.prototype.toString;function o(e){return"[object String]"===n.call(e)}function r(e){return"[object Number]"===n.call(e)}var a=Object.prototype.hasOwnProperty;e.exports=function e(t,n){if((s=t)==(c=n)&&(o(s)||r(s))&&(o(c)||r(c))||function(e,t){return e===t?0!==e||1/e==1/t:e!=e&&t!=t}(s,c))return!0;var s,c;if("object"!=typeof t||null===t||"object"!=typeof n||null===n)return!1;if(t instanceof Array&&n instanceof Array){if(t.length!==n.length)return!1;for(var i,l=t.length,p=new Array(l),u=0;u<l;u++)if(e(i=t[u],n[u]))p[u]=!0;else{for(var d=!1,b=0,m=n.length;b<m;b++)if(!p[b]&&e(i,n[b])){p[b]=!0,d=!0;break}if(!d)return!1}return!0}var f=Object.keys(t),M=Object.keys(n);if(f.length!==M.length)return!1;for(var z=0;z<f.length;z++)if(!a.call(n,f[z])||!e(t[f[z]],n[f[z]]))return!1;return!0}},,function(e,t,n){"use strict";
