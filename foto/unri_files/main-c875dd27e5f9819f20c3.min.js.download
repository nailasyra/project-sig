 Kim Cheng",testimony:'“Saya sangat senang mendapat kesempatan untuk bekerja di Jepang dengan lingkungan kerja baru dan mendapatkan pengalaman. KIT Cambodia telah membantu meningkatkan Bahasa Inggris, keterampilan komunikasi, keterampilan memimpin, serta memberikan kesempatan belajar. Setelah bekerja di Jepang, saya ingin berbagi pengalaman kerja dan ingin membantu teman-teman di kampus untuk menemukan peluang kerja mereka. Untuk semua junior, "Jangan ragu dan kejar passionmu!”',img:"/assets/img/kit-landing/testimonies/mr-kim-cheng-kit-cambodia-quipper-campus.jpg",imgAlt:"Mr Kim Cheng KIT Cambodia | Quipper Campus"}],hj=()=>r.a.createElement("div",{id:"testimonials",className:"testimonials"},r.a.createElement(mn,null,r.a.createElement(Pa,{component:"h2",variant:"title",className:"testimonials__title text-center"},"Testimoni"),r.a.createElement(Mn,null,r.a.createElement(xn,{md:"12"},zj.map((e,t)=>r.a.createElement(fj,Mj({key:"testimony-".concat(t)},e))))))),{assets_url:Oj}=Ie,gj=({img:e,imgAlt:t,title:n,desc:o})=>r.a.createElement("div",{className:"kit-majors__item"},r.a.createElement(zo,{className:"kit-majors__card"},r.a.createElement(Bo,{src:"".concat(Oj).concat(e||"/assets/img/placeholder-jurusan.svg"),alt:t||n,className:"img-responsive",top:!0}),r.a.createElement(qo,null,r.a.createElement(Ho,null,n),r.a.createElement("div",{className:"card-text"},r.a.createElement(Pa,{component:"p",variant:"body"},o)))));gj.propTypes={img:a.string,title:a.string,desc:a.string,imgAlt:a.string};var Aj=gj;function xj(){return(xj=Object.assign||function(e){for(var t=1;t<arguments.length;t++){var n=arguments[t];for(var o in n)Object.prototype.hasOwnProperty.call(n,o)&&(e[o]=n[o])}return e}).apply(this,arguments)}var yj=[{id:"1",title:"Software Engineering",desc:"Quipperian akan mendapatkan silabus dan kurikulum pembelajaran yang senantiasa diperbarui setiap semester mengikuti perkembangan teknologi yang ada. Dengan begitu kesenjangan yang sering terjadi antara dunia perkuliahan dengan industri dapat diatasi. Dengan sistem belajar yang unik, kreatif, dan inovatif, Jurusan Software Engineering memiliki metode pembelajaran berbasis proyek, yang memberikan kesempatan kepada kamu untuk siap bekerja di negara-negara maju, khususnya Jepang.",img:"/assets/img/kit-landing/majors/belajar-software-engineering-di-kit-cambodia-quipper-campus.jpg",imgAlt:"Belajar Software Engineering di KIT Cambodia | Quipper Campus"},{id:"2",title:"Faculty of International Leaders Hospitality Management",desc:"Tidak hanya di Kamboja, kamu juga mendapatkan kesempatan pengalaman kerja di negara-negara ASEAN dan kemudian Jepang serta negara lain di seluruh dunia dengan belajar di Jurusan International Leaders Hospitality Management. Selain itu, Quipperian juga akan memperoleh kegiatan lapangan berskala internasional, yang akan mengajarkan kamu cara memulai bisnis yang baik di sektor ini.",img:"/assets/img/kit-landing/majors/belajar-international-leaders-hospitality-management-di-kit-cambodia-quipper-campus.jpg",imgAlt:"Belajar International Leaders Hospitality Management di KIT Cambodia | Quipper Campus"}].map((e,t)=>r.a.createElement(Aj,xj({},e,{key:"mjr-itm-".concat(e.id,"-").concat(t)}))),vj=()=>r.a.createElement("div",{id:"kit-majors",className:"kit-majors"},r.a.createElement(mn,null,r.a.createElement(Pa,{component:"h2",variant:"title",className:"kit-majors__title text-center"},"Jurusan"),Re&&window.outerWidth>=768?r.a.createElement(Mn,{className:"d-flex a-i-stretch"},yj.map((e,t)=>r.a.createElement(xn,{md:"6",key:"m-itm-".concat(t,"-").concat(e.id)},e))):r.a.createElement(Qy,{id:"major-crsl",items:yj}))),qj=({no:e,title:t,children:n})=>r.a.createElement(r.a.Fragment,null,r.a.createElement("div",{className:"dots"}),r.a.createElement(Zg,null,r.a.createElement("div",{className:"enrollment-steps__item"},r.a.createElement("div",{className:"enrollment-steps__item-icon"},r.a.createElement(dt,{src:"/assets/img/kit-landing/icons/enroll-".concat(e,".svg"),alt:"Enrollment KIT Cambodi