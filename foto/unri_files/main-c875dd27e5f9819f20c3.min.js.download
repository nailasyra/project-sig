sarkan hasil RIASEC ini, kamu bisa menemukan karier apa saja yang sesuai dengan kepribadianmu. Setiap karier akan mempunyai kriteria kemampuan yang bermacam-macam. Kamu bisa mempersiapkan diri sesuai dengan karier yang kamu cita-citakan. Bagi kamu yang belum memiliki gambaran karier yang kamu inginkan, kamu juga bisa melihat jurusan yang sesuai dengan kepribadianmu. Tidak perlu khawatir, karena setiap jurusan mempunyai peluang karier yang beragam! Jadi, kamu bisa menentukan langkah karier kamu setelah kamu kuliah di jurusan tersebut. Semoga sukses ya, Quipperian!"))),r.a.createElement(Ee.a,{id:"3357745886"},[".aptitude-result.jsx-3357745886{background-color:#f5fcff;}","@media screen and (max-width:767px){.aptitude-result.jsx-3357745886 .campus-section{padding-top:40px;}}",".aptitude-result__wrapper{position:relative;padding:100px;}","@media screen and (max-width:767px){.aptitude-result__wrapper{padding:200px;}}",".aptitude-result__riasec{margin:64px 0 !important;}","@media screen and (max-width:767px){.aptitude-result__riasec{margin:30px 0 !important;}}",".aptitude-result__recommendation.jsx-3357745886{position:absolute;top:50px;margin:0 50px;padding:20px 30px;background-color:#fff;box-shadow:0 6px 16px 0 rgba(107,143,188,0.1);}",".aptitude-result__recommendation.jsx-3357745886 p{font-size:12px !important;}",".aptitude-result__recommendation.jsx-3357745886 p,h4{color:#0c2846 !important;}","@media screen and (max-width:767px){.aptitude-result__recommendation.jsx-3357745886{margin:0 10px;left:0px;top:50px;}}"]))};fM.propTypes={comment:a.string,ratio:a.object};var MM=fM,{assets_url:zM}=Ie,hM="".concat(zM,"/assets/img/aptitude/report"),OM=({name:e})=>r.a.createElement("div",{className:"jsx-2724091798 aptitude-greeting"},r.a.createElement(gd,{paddingTop:80,paddingBottom:120,backgroundColor:"transparent"},r.a.createElement(ei,null,r.a.createElement("div",{className:"jsx-2724091798 aptitude-greeting__wrapper"},r.a.createElement(Pa,{component:"h2",variant:"title",className: