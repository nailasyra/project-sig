th":"/majors/id-pendidikan-anak-usia-dini-paud"},{"name":"Keguruan &amp; Pendidikan","path":"/majors/id-keguruan-pendidikan"},{"name":"Bimbingan dan Konseling","path":"/majors/id-bimbingan-konseling"},{"name":"Pendidikan Luar Sekolah","path":"/majors/id-pendidikan-luar-sekolah"},{"name":"Sastra Jepang","path":"/majors/id-sastra-jepang"}]}},{"id":"5a5497fb8020391fb40011da","slug":"fakultas-ekonomi-dan-bisnis","name":"Fakultas Ekonomi dan Bisnis","description":"Fakultas Ekonomi dan Bisnis dibuka pada tahun 1963, setahun setelah Universitas Riau diresmikan dengan adanya Surat Keputusan Menteri Perguruan Tinggi dan Ilmu Pengetahuan No. 123.  Fakultas Ekonomi dan Bisnis Unri memiliki visi menjadi Fakultas Ekonomi dan Bisnis berkelas dunia dalam pengembangan IPTEK yang berorientasi pada perekonomian dan bisnis di Kawasan Asia Tenggara 2035. FEB Unri juga menjalin kerja sama dengan BPKN sebagai wujud keterlibatan nyata di Era Masyarakat Ekonomi ASEAN.","applicant_count":3179,"accepted_count":272,"admission_rate":8.6,"admission_source":"SBMPTN 2019 | Kuota 2020: 336","static_majors":[],"subjects":{"Ilmu Ekonomi":["Pengantar Ilmu Ekonomi","Ekonomi Sumber Daya Manusia","Ekonomi Lingkungan","Ekonomi Pertanian","Ekonomi Regional"],"Perpajakan":["Dasar-dasar Perpajakan","Pajak Penghasilan Orang Pribadi","Kepabeanan dan Cukai","Peradilan Pajak","Perpajakan Internasional"],"Akuntansi":["Perpajakan / KUP","Akuntansi Biaya","Akuntansi Keuangan","Sistem Informasi Akuntansi","Pajak Penghasilan"],"Manajemen":["Manajemen Operasional","Manajemen Pemasaran","Manajemen Sumber Daya Manusia","Manajemen Keuangan","Strategi Pemasaran"]},"careers":["Akuntan","Auditor","Analis  Keuangan","Ekonom","Manajer","Konsultan","Peneliti","Pengusaha","Pendidik"],"majors":{"s1":[{"name":"Akuntansi (A)","study_plans":["Perpajakan/KUP (Ketentuan Umum Perpajakan)","Sistem Informasi Akuntansi ","Akuntansi Keuangan "," Akuntansi Biaya ","Pajak Penghasilan"]},{"name":"Manajemen (A)","study_plans":["Manajemen Pemasaran ","Manajemen Operasional "," Manajemen Keuangan","Manajemen Sumber Daya Manusia"," Strategi Pemasaran"]},{"name":"Ekonomi Pembangunan (A)","study_plans":[" Ekonomi Sumber Daya Manusia","Ekonomi Pertanian ","Pengantar Ilmu Ekonomi"," Ekonomi Lingkungan ","Ekonomi Regional"]}],"d3":[{"name":"Akuntansi (A)","study_plans":[]},{"name":"Perpajakan (B)","study_plans":[]}],"profesi":[{"name":"Akuntan (B)","study_plans":[]}]},"study_fields":["Perpajakan","Akuntansi","Manajemen","Ekonomi Pembangunan"],"related_majors":{"list":[{"name":"Perpajakan","path":"/majors/id-perpajakan"},{"name":"Akuntansi","path":"/majors/id-akuntansi"},{"name":"Manajemen","path":"/majors/id-manajemen"},{"name":"Ekonomi Pembangunan","path":"/majors/id-ekonomi-pembangunan"}]}},{"id":"5a5497fb8020391fb40011e3","slug":"fakultas-matematika-dan-ilmu-pengetahuan-alam","name":"Fakultas Matematika dan Ilmu Pengetahuan Alam","description":"FMIPA Unri dibuka tahun 1963 bersamaan dengan diresmikannya Universitas Riau dan awalnya bernama Fakultas Ilmu Pasti dan Ilmu Alam (FIPIA) yang memiliki tiga jurusan yaitu Jurusan Ilmu Pasti, Fisika dan Kimia. Pada tahun 1963, FIPIA diubah namanya menjadi FMIPA (Fakultas Matematika dan Ilmu Pengetahuan Alam). Sekarang, FMIPA memiliki banyak jurusan yang bisa Quipperian jadikan pilihan.","applicant_count":2404,"accepted_count":241,"admission_rate":10.0,"admission_source":"SBMPTN 2019 | Kuota 2020: 240","static_majors":[],"subjects":{"Sistem informasi":["Sistem operasi","Pemrograman web","Sistem pendukung keputusan","Web lanjut","Kapita selekta SIG"],"Matematika":["Matematika aktuaria","Fisika matematika","Riset operasi deterministic","Peng diff geometri","Proses stokastik"],"Fisika":["Mekanika","Elektrodinamika","Fisika Inti","Fisika Kuantum","Fisika Eksperimen"],"Kimia":["Struktur Biomolekul dan Enzim","Sintesis Kimia Anorganik","Toksikologi Kimia","Analisis Kimia","Metode Pemisahan"],"Biologi":["Etnobiologi","Geologi","Biostatistika","Taksonomi","Klimatologi"]},"car