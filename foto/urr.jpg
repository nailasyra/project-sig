      <script type="application/json" data-hypernova-key="SiteRoot" data-hypernova-id="058e24c0-1abb-4d7d-85be-dfb53b49b8a5"><!--{"is_search_engine":false,"locale":"id","breadcrumbs":[{"name":"Directory","url":"/directory"},{"name":"Universitas Riau (Unri)","url":"/directory/universitas-riau"}],"currentUser":null,"params":{"id":"universitas-riau"},"currentPath":"/directory/universitas-riau","school":{"id":"591c31a156514300520005c5","slug":"universitas-riau","name":"Universitas Riau (Unri)","logo":"https://media.quipper.com/media/W1siZiIsIjIwMTgvMDEvMjkvMDYvNDEvMjgvZGY2NWRmZjUtOGVhNC00ZjdmLWI3M2ItNTFiMDYzMjdlZmViLyJdLFsicCIsInRodW1iIiwiODh4ODgiXV0","images":[{"id":"5a6ec2188020394c8000076e","description":null,"original_url":"https://media.quipper.com/media/W1siZiIsIjIwMTgvMDEvMjkvMDYvNDEvMjgvMmE5NjY4ZmQtYzk5My00Zjc0LWEzN2EtY2RiMzc0NmEwNDQyLyJdLFsicCIsInRodW1iIiwiMTIwMHhcdTAwM2UiXSxbInAiLCJjb252ZXJ0IiwiLWNvbG9yc3BhY2Ugc1JHQiAtc3RyaXAiLHsiZm9ybWF0IjoianBnIn1dXQ","thumb_url":"https://media.quipper.com/media/W1siZiIsIjIwMTgvMDEvMjkvMDYvNDEvMjgvMmE5NjY4ZmQtYzk5My00Zjc0LWEzN2EtY2RiMzc0NmEwNDQyLyJdLFsicCIsInRodW1iIiwiODh4ODgiXSxbInAiLCJjb252ZXJ0IiwiLWNvbG9yc3BhY2Ugc1JHQiAtc3RyaXAiLHsiZm9ybWF0IjoianBnIn1dXQ","medium_url":"https://media.quipper.com/media/W1siZiIsIjIwMTgvMDEvMjkvMDYvNDEvMjgvMmE5NjY4ZmQtYzk5My00Zjc0LWEzN2EtY2RiMzc0NmEwNDQyLyJdLFsicCIsInRodW1iIiwiNDE0eDE2MCJdLFsicCIsImNvbnZlcnQiLCItY29sb3JzcGFjZSBzUkdCIC1zdHJpcCIseyJmb3JtYXQiOiJqcGcifV1d"}],"brochure":null,"facilities":{"Fasilitas Olahraga":0,"Poliklinik":0,"Wisma Universitas Riau":2,"Unit Pelayanan dan Pengembangan Bahasa-UP2B":0,"Koperasi Pegawai Negeri":0,"Pusat Pengembangan Karir dan Kewirausahaan-P2K2":1,"Perpustakaan":1,"Badan Eksekutif Mahasiswa":0,"Masjid Universitas Riau":2,"Lembaga Pengabdian Masyarakat-LPM":1,"UR Press":0,"Pusat Komputer-PUSKOM":0,"Kantor Urusan Internasional":0,"Pusat Pelatihan":0,"Laboratorium Teknologi Hasil Perikanan ":0,"Laboratorium Kimia Hasil Perikanan ":0,"Laboratorium  Mikrobiologi dan Bioteknologi Hasil Perikanan ":0,"Lab Electronic Data Processing ":0,"Lab Sistem Terdistribusi":0," Lab Multimedia ":0,"Laboratorium Fotomikrografi ":0,"Laboratorium Teknik Pertanian ":0,"Laboratorium Komputer dan Pengolahan Data":0},"tuition_fee":"<p&gt;<span style=\"font-weight: 400;\"&gt;Biaya kuliah yang digunakan di Universitas Riau menggunakan sistem Uang Kuliah Tunggal (UKT) yang sudah diberlakukan dari tahun 2013. Sistem UKT bagi mahasiswa Universitas Riau berlaku untuk semua jalur penerimaan mahasiswa mulai dari SNMPTN, SBMPTN, dan Mandiri sebesar Rp500.000-Rp23.400.000 yang kemudian disesuaikan berdasarkan latar belakang ekonomi orang tua atau pihak yang membiayai.</span&gt;</p&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;Berikut rincian UKT program Sarjana tahun ajaran 2022/2023 berdasarkan kelompok penghasilan (dalam rupiah):</span&gt;<span style=\"font-weight: 400;\"&gt;&amp;nbsp;</span&gt;</p&gt;\r\n<table&gt;\r\n<tbody&gt;\r\n<tr&gt;\r\n<th rowspan=\"2\"&gt;\r\n<h1&gt;<strong&gt;Fakultas/Jurusan</strong&gt;</h1&gt;\r\n</th&gt;\r\n<th colspan=\"2\"&gt;\r\n<h1&gt;<strong&gt;Kelompok UKT</strong&gt;</h1&gt;\r\n</th&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<th&gt;\r\n<h1&gt;<strong&gt;Kelompok I-III</strong&gt;</h1&gt;\r\n</th&gt;\r\n<th&gt;\r\n<h1&gt;<strong&gt;Kelompok IV-VI</strong&gt;</h1&gt;\r\n</th&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;Fakultas​ ​Matematika​ ​dan​ ​Ilmu Pengetahuan Alam&amp;nbsp;</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;500.000-2.050.000</span&gt;</h1&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;3.175.000-6.100.000</span&gt;</h1&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;Fakultas​ ​Ilmu Sosial dan Ilmu Politik&amp;nbsp;</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;500.000-2.050.000</span&gt;</h1&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;2.125.000-4.300.000</span&gt;</h1&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;Fakultas​ ​Perikanan dan Kelautan</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;500.000-2.050.000</span&gt;</h1&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;3.250.000-6.200.000</span&gt;</h1&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;Fakultas​ ​Keguruan dan Ilmu Pendidikan&amp;nbsp;</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;500.000-2.050.000</span&gt;</h1&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;2.050.000-4.600.000</span&gt;</h1&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;Fakultas​ ​Ekonomi dan Bisnis</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;500.000-2.050.000</span&gt;</h1&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;2.200.000-7.400.000</span&gt;</h1&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;Fakultas​ ​Pertanian&amp;nbsp;</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;500.000-2.050.000</span&gt;</h1&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;2.925.000-5.800.000</span&gt;</h1&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;Fakultas​ ​Kedokteran&amp;nbsp;</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;500.000-6.175.000</span&gt;</h1&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;11.175.000-23.400.000</span&gt;</h1&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;Fakultas​ ​Teknik&amp;nbsp;</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;500.000-2.050.000</span&gt;</h1&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;3.175.000-5.550.000</span&gt;</h1&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;Fakultas​ ​Hukum&amp;nbsp;</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;500.000-2.050.000</span&gt;</h1&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;2.825.000-5.050.000</span&gt;</h1&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;Fakultas​ ​ Keperawatan</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;500.000-2.050.000</span&gt;</h1&gt;\r\n</td&gt;\r\n<td&gt;\r\n<h1&gt;<span style=\"font-weight: 400;\"&gt;4.550.000-8.550.000</span&gt;</h1&gt;\r\n</td&gt;\r\n</tr&gt;\r\n</tbody&gt;\r\n</table&gt;","entrance_exam":"<p&gt;<span style=\"font-weight: 400;\"&gt;Berikut​ ​informasi​ ​seleksi​ ​masuk​ ​yang​ ​dapat​ ​Quipperian​ jadikan ​​bahan​ ​rujukan​ ​jika​ ​kalian menjadikan​ ​Unri sebagai ​pilihan​ untuk melanjutkan​ ​studi selanjutnya!​</span&gt; <span style=\"font-weight: 400;\"&gt;&amp;nbsp;&amp;nbsp;</span&gt;</p&gt;\r\n<table&gt;\r\n<tbody&gt;\r\n<tr&gt;\r\n<th rowspan=\"4\"&gt;\r\n<p&gt;<span&gt;1.</span&gt;</p&gt;\r\n</th&gt;\r\n<th&gt;\r\n<p&gt;<span&gt;Seleksi</span&gt;</p&gt;\r\n</th&gt;\r\n<th&gt;\r\n<p&gt;<span&gt;SNMPTN</span&gt;</p&gt;\r\n</th&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<th&gt;\r\n<p&gt;<span&gt;Tahapan</span&gt;</p&gt;\r\n</th&gt;\r\n<td&gt;\r\n<ol&gt;\r\n<li aria-level=\"1\"&gt;<span&gt;Registrasi Akun LTMPT (10 Januari-15 Februari 2022)</span&gt;</li&gt;\r\n<li aria-level=\"1\"&gt;<span&gt;Pengisian PDSS (8 Januari-8 Februari 2022)</span&gt;</li&gt;\r\n<li aria-level=\"1\"&gt;<span&gt;Verifikasi PDSS</span&gt;</li&gt;\r\n<li aria-level=\"1\"&gt;<span&gt;Pendaftaran online (14-28 Februari 2022)</span&gt;</li&gt;\r\n<li aria-level=\"1\"&gt;<span&gt;Pencetakan kartu peserta</span&gt;</li&gt;\r\n<li aria-level=\"1\"&gt;<span&gt;Proses seleksi</span&gt;</li&gt;\r\n<li aria-level=\"1\"&gt;<span&gt;Pengumuman (29 Maret 2022)</span&gt;</li&gt;\r\n</ol&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<th&gt;\r\n<p&gt;<span&gt;Biaya Pendaftaran</span&gt;</p&gt;\r\n</th&gt;\r\n<td&gt;\r\n<p&gt;<span&gt;Gratis</span&gt;</p&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<th&gt;\r\n<p&gt;<span&gt;Waktu Pelaksanaan</span&gt;</p&gt;\r\n</th&gt;\r\n<td&gt;\r\n<p&gt;<span&gt;Januari-Maret 2022</span&gt;</p&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<th rowspan=\"4\"&gt;\r\n<p&gt;<span&gt;2.</span&gt;</p&gt;\r\n</th&gt;\r\n<th&gt;\r\n<p&gt;<span&gt;Seleksi</span&gt;</p&gt;\r\n</th&gt;\r\n<th&gt;\r\n<p&gt;<span&gt;UTBK-SBMPTN</span&gt;</p&gt;\r\n</th&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<th&gt;\r\n<p&gt;<span&gt;Tahapan</span&gt;</p&gt;\r\n</th&gt;\r\n<td&gt;\r\n<ol&gt;\r\n<li aria-level=\"1\"&gt;<span&gt;Registrasi akun Siswa LTMPT (14 Februari-17 Maret 2022)</span&gt;</li&gt;\r\n<li aria-level=\"1\"&gt;<span&gt;Verifikasi dan validasi data</span&gt;</li&gt;\r\n<li aria-level=\"1\"&gt;<span&gt;Pendaftaran (23 Maret-15 April 2022)</span&gt;</li&gt;\r\n<li aria-level=\"1\"&gt;<span&gt;Pembayaran UTBK</span&gt;</li&gt;\r\n<li aria-level=\"1\"&gt;<span&gt;Pelaksanaan UTBK</span&gt;</li&gt;\r\n<ul&gt;\r\n<li aria-level=\"1\"&gt;<span&gt;Tahap 1 (17-23 Mei 2022)</span&gt;</li&gt;\r\n<li aria-level=\"1\"&gt;<span&gt;Tahap 2 (28 Mei-3 Juni 2022)</span&gt;</li&gt;\r\n</ul&gt;\r\n<li aria-level=\"1\"&gt;<span&gt;Pengumuman SBMPTN (23 Juni 2022)</span&gt;</li&gt;\r\n</ol&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<th&gt;\r\n<p&gt;<span&gt;Biaya Pendaftaran</span&gt;</p&gt;\r\n</th&gt;\r\n<td&gt;\r\n<p&gt;<span&gt;Kelompok Saintek/Soshum: Rp200.000</span&gt;</p&gt;\r\n<p&gt;<span&gt;Kelompok Campuran: Rp300.000</span&gt;</p&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<th&gt;\r\n<p&gt;<span&gt;Waktu Pelaksanaan</span&gt;</p&gt;\r\n</th&gt;\r\n<td&gt;\r\n<p&gt;<span&gt;14 Februari-31 Juli 2022</span&gt;</p&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<th rowspan=\"4\"&gt;\r\n<p&gt;<span&gt;3.</span&gt;</p&gt;\r\n</th&gt;\r\n<th&gt;\r\n<p&gt;<span&gt;Seleksi</span&gt;</p&gt;\r\n</th&gt;\r\n<th&gt;\r\n<p&gt;<span&gt;Seleksi Mandiri Masuk Perguruan Tinggi Negeri-Barat (SMMPTN-BARAT)</span&gt;</p&gt;\r\n</th&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<th&gt;\r\n<p&gt;<span&gt;Tahapan</span&gt;</p&gt;\r\n</th&gt;\r\n<td&gt;\r\n<ol&gt;\r\n<li aria-level=\"1\"&gt;<span&gt;Pendaftaran peserta dan pembayaran registrasi (1 April-27 Juni 2022)</span&gt;</li&gt;\r\n<li aria-level=\"1\"&gt;\r\n<h3&gt;<span style=\"font-weight: 400;\"&gt;Ujian Tulis Berbasis Komputer (UTBK)</span&gt; <span style=\"font-weight: 400;\"&gt;(</span&gt;<span style=\"font-weight: 400;\"&gt;30 Juni-14 Juli 2022</span&gt;<span style=\"font-weight: 400;\"&gt;)</span&gt;</h3&gt;\r\n</li&gt;\r\n<li aria-level=\"1\"&gt;<span&gt;Pengumuman (18 Juli 2022)</span&gt;</li&gt;\r\n</ol&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<th&gt;\r\n<p&gt;<span&gt;Biaya Pendaftaran</span&gt;</p&gt;\r\n</th&gt;\r\n<td&gt;\r\n<p&gt;<span&gt;Rp350.000</span&gt;</p&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<th&gt;\r\n<p&gt;<span&gt;Waktu Pelaksanaan</span&gt;</p&gt;\r\n</th&gt;\r\n<td&gt;\r\n<p&gt;<span&gt;1 April-18 Juli 2022</span&gt;</p&gt;\r\n</td&gt;\r\n</tr&gt;\r\n</tbody&gt;\r\n</table&gt;","scholarship":"<p&gt;<span style=\"font-weight: 400;\"&gt;Universitas Riau memiliki sejumlah beasiswa menarik bagi para mahasiswa, baik dana bantuan dari pemerintah maupun instansi swasta yang menjadi mitra kerjasama dengan kampus. Untuk mengetahui informasi ter-</span&gt;<em&gt;<span style=\"font-weight: 400;\"&gt;update</span&gt;</em&gt;<span style=\"font-weight: 400;\"&gt; dari beragam program beasiswa Unri, kamu bisa langsung visit ke website kampus terkait ya, Quipperian!</span&gt;</p&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;Berikut ini beberapa program beasiswa Universitas Riau:</span&gt;</p&gt;\r\n<table&gt;\r\n<tbody&gt;\r\n<tr&gt;\r\n<th&gt;\r\n<p&gt;<strong&gt;Nama Beasiswa</strong&gt;</p&gt;\r\n</th&gt;\r\n<th&gt;\r\n<p&gt;<strong&gt;Penjelasan</strong&gt;</p&gt;\r\n</th&gt;\r\n<th&gt;\r\n<p&gt;<strong&gt;Besaran Beasiswa</strong&gt;</p&gt;\r\n</th&gt;\r\n<th&gt;\r\n<p&gt;<strong&gt;Waktu Pendaftaran</strong&gt;</p&gt;\r\n</th&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;KIP Kuliah</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;Program beasiswa yang disediakan oleh pemerintah melalui Kemendikbud kepada mahasiswa berprestasi yang memiliki keterbatasan ekonomi</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;Bantuan biaya hidup sebesar Rp700.000 per-bulan</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;2 Februari-31 Oktober 2022</span&gt;</p&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;Beasiswa Peningkatan Prestasi Akademik (PPA)</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;Beasiswa ini diberikan oleh Kemenristekdikti kepada mahasiswa Diploma semester I-Vdan Sarjana semester II-VII dengan pencapaian Indeks Prestasi Komulatif (IPK) paling rendah 3,25</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;-</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;6-30 Juni 2022</span&gt;</p&gt;\r\n</td&gt;\r\n</tr&gt;\r\n<tr&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;Beasiswa Bantuan Belajar Mahasiswa 2022</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;Beasiswa ini diberikan kepada mahasiswa jenjang S1 aktif yang berasal dari latar belakang ekonomi kurang mampu</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;-</span&gt;</p&gt;\r\n</td&gt;\r\n<td&gt;\r\n<p&gt;<span style=\"font-weight: 400;\"&gt;20 April 2022</span&gt;</p&gt;\r\n</td&gt;\r\n</tr&gt;\r\n</tbody&gt;\r\n</table&gt;","paid":false,"article_tags":[],"campus_sector":"public_university","profile":{"description":"Mengusung visi “Menjadi Universitas Riset Unggul Bermartabat di Bidang Riset dan Teknologi di Kawasan Asia tenggara tahun 2035”, Universitas Riau terus memperkuat resources dan terus mengembangkan berbagai inovasi. Para tenaga pengajar di tiap jurusan, terutama di bidang sains dan teknologi bersinergi, mengembangkan inovasi berbasis science melalui pengajaran dan juga riset. Selain itu, kampus ini juga menyediakan lebih dari 100 laboratorium sebagai wadah bagi mahasiswa dalam mengambangkan kemampuan di bidang teknologi.\r\n\r\nNggak hanya memperkuat sumber daya inti dari dalam kampus, Unri juga menjalin kerja sama dengan berbagai mitra untuk meningkatkan kualitas kampus di bidang teknologi, lho! Salah satunya, kampus ini menjalin kerja sama dengan Chevron Pacific Indonesia (PT CPI) untuk meningkatkan kualitas lulusan di bidang teknik kimia. Penasaran dengan profil lengkap kampus ini? Cek profilnya berikut ini, yuk!\r\n\r\n","accreditation":"A","tuition_fee_snippet":"Rp3.500.000 ​kisaran​ ​​per-semester","teacher_count":2244,"student_count":35358,"sector":"public","teacher_student_ratio":"1:15","address":"Kampus Bina Widya Km 12,5, Simpang Baru Pekanbaru 28293","website":"www.unri.ac.id","email":"rektor@unri.ac.id ","phone_number":"0761-63266","social_media":{"blog":"","facebook":"https://www.facebook.com/humasuniversitasriau","instagram":"https://www.instagram.com/humasuniversitasriau","youtube":"https://www.youtube.com/huma suniversitasriau","twitter":"https://www.twitter.com/univ_riau"},"main_video":null},"faculties":[{"id":"591c31a156514300520005fa","slug":"fakultas-pertanian","name":"Fakultas Pertanian","description":"Tahun 1981, Unri membuka Fakultas Non Gelar Teknologi (FNGT) dengan Jurusan Penyuluhan Pertanian dan Teknik Sipil. Kemudian, pada tahun 1991, FNGT ditutup dan dibuka Fakultas Pertanian. Fakultas Pertanian Universitas Riau memiliki visi menjadi Lembaga Pendidikan Tinggi Pertanian terkemuka dalam pengembangan ilmu bidang Agro-Teknopreneurship berbasis sumber daya lokal tahun 2020. ","applicant_count":2741,"accepted_count":221,"admission_rate":8.1,"admission_source":"SBMPTN 2019 | Kuota 2020: 192","static_majors":[],"subjects":{"Agroteknologi":["Dasar-dasar ilmu tanah","Bioteknologi tanaman","Fisiologi tumbuhan","Pertanian terpadu","Komunikasi pertanian"],"Teknologi hasil pertanian":["Gizi dan pangan","Perencanaan industry pertanian","Analisis hasil pertanian","Teknologi lemak dan minyak","Teknologi hasil hewani"],"Agribisnis":["Teknologi perlindungan tanaman","Politik dan pembangunan pertanian","Manajemen agribisnis","Bisnis finansial","Manajemen agrowisata"],"Kehutanan":["Klimatologi hutan","Sosiologi kehutanan","Ekologi restorasi","Praktik tata kelola hutan","Ergonomik"]},"careers":["Departemen Pertanian","Entrepreneur","Konsultan","Lembaga Penelitian","Badan Pusat Statistik"],"majors":{"s1":[{"name":"Kehutanan (B)","study_plans":[" Sosiologi Kehutanan","Klimatologi Hutan","Praktik Tata Kelola Hutan ","Ergonomik"," Ekologi Restorasi "]},{"name":"Agribisnis (A)","study_plans":["Manajemen Agrowisata"," Politik dan Pembangunan Pertanian","Teknologi Perlindungan Tanaman"," Manajemen Agribisnis ","Bisnis Finansial "]},{"name":"Agroteknologi (A)","study_plans":["Pertanian Terpadu","Fisiologi Tumbuhan "," Bioteknologi Tanaman "," Komunikasi Pertanian","Dasar-Dasar Ilmu Tanah"]},{"name":"Teknologi Hasil Pertanian (B)","study_plans":[" Analisis Hasil Pertanian "," Teknologi Hasil Hewani","Gizi dan Pangan"," Perencanaan Industri Pertanian","Teknologi Lemak dan Minyak"]},{"name":"Teknologi Industri Pertanian (B)","study_plans":[" Peralatan Industri Pertanian ","Pengantar Teknologi Pertanian","Bioteknologi Industri "," Dasar Rekayasa Bioproses","Fisiologi dan Teknologi Pasca Panen"]}]},"study_fields":["Kehutanan","Agroteknologi","Ilmu dan Teknologi Pangan","Agribisnis"],"related_majors":{"list":[{"name":"Kehutanan","path":"/majors/id-kehutanan"},{"name":"Agroteknologi","path":"/majors/id-agroteknologi"},{"name":"Ilmu dan Teknologi Pangan","path":"/majors/id-ilmu-dan-teknologi-pangan"},{"name":"Agribisnis","path":"/majors/id-agribisnis"}]}},{"id":"591c31a156514300520005f4","slug":"fakultas-perikanan-dan-ilmu-kelautan","name":"Fakultas Perikanan dan Ilmu Kelautan","description":"Fakultas Perikanan dan Ilmu Kelautan Universitas Riau dikenal sebagai Fakultas Perikanan dan Ilmu Kelautan terbaik di wilayah Sumatera dan Kalimantan. Faperika Unri memiliki tenaga pengajar dengan jumlah profesor terbanyak di antara fakultas lainnya yang dimiliki oleh Universitas Riau.","applicant_count":1775,"accepted_count":238,"admission_rate":13.4,"admission_source":"SBMPTN 2019 | Kuota 2020: 256","static_majors":[],"subjects":{"Sosial Ekonomi Perikanan":["Sosiologi Pedesaan","Tataniaga Hasil Perikanan","Akuntansi Agrobisnis Perikanan","Ekonomi Perikanan","Sosiologi Masyarakat Pesisir"],"Ilmu Kelautan":["Avertebrata Air","Iktiologi","Ekologi Perairan","Fisiologi Hewan Air","Penginderaan Jauh Kelautan"],"Teknologi Hasil Perairan":["Biologi Perikanan","Teknologi Pengolahan Hasil Perikanan","Gizi Ikani","Toksikologi dan Sanitasi","Teknologi Pengemasan dan Penyimpanan Hasil Perikanan"],"Budidaya Perairan":["Rancangan percobaan","Ilmu nutrisi hewan air","Manajemen pembenihan ikan","Media akuakultur","Analisis penyakit ikan"],"Manajemen Sumberdaya Perairan":["Dasar-dasar Budidaya Perairan","Limnologi","Produktifitas Perairan","Manajemen DAS dan Rawa Gambut","Mikrobiologi Perairan"],"Pemanfaatan Sumberdaya Perikanan":["Meteorologi Laut","Permesinan Kapal Perikanan","Alat Bantu Penangkapan Ikan","Perencanaan Industri Penangkapan Ikan","Analis Teknologi Penangkapan Ikan"]},"careers":["Pengajar dan Akademisi","Pegawai Negeri Sipi